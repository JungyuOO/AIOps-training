{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenShift AIOps SFT sample",
  "type": "object",
  "required": [
    "id",
    "category",
    "difficulty",
    "expected_cause",
    "symptoms",
    "must_mention",
    "forbidden_actions",
    "source",
    "generator",
    "version",
    "messages"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": [
        "application_connectivity",
        "configuration_identity",
        "storage_data_artifacts",
        "accelerator_serving_runtime",
        "platform_lifecycle_capacity"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": ["basic", "intermediate", "advanced"]
    },
    "expected_cause": { "type": "string", "minLength": 1 },
    "symptoms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "must_mention": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "forbidden_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source": { "type": "string" },
    "generator": { "type": "string" },
    "version": { "type": "string" },
    "messages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant"] },
          "content": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
